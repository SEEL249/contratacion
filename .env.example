# =============================================================================
# Variables de entorno — copiar a .env.local y completar
# =============================================================================

# --- Base de datos (PostgreSQL / Neon) ---
# Conexión pooled para la app y directa (UNPOOLED) para migraciones (Prisma).
DATABASE_URL="postgresql://user:password@localhost:5432/contratacion?schema=public"
DATABASE_URL_UNPOOLED="postgresql://user:password@localhost:5432/contratacion?schema=public"

# --- Auth.js (NextAuth v5) ---
AUTH_SECRET="genera-uno-con: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# --- IA (compatible OpenAI: xAI Grok o Groq) ---
# xAI:  BASE_URL=https://api.x.ai/v1            MODEL=grok-2-latest
# Groq: BASE_URL=https://api.groq.com/openai/v1 MODEL=llama-3.3-70b-versatile
GROK_API_KEY=""
GROK_API_BASE_URL="https://api.groq.com/openai/v1"
GROK_MODEL="llama-3.3-70b-versatile"

# --- Almacenamiento de archivos (Vercel Blob / S3) ---
BLOB_READ_WRITE_TOKEN=""
# Alternativa S3:
# S3_ENDPOINT=""
# S3_BUCKET=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_REGION=""

# --- Correo (SMTP de correo personal, p. ej. Gmail) ---
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=tucorreo@gmail.com,
#        SMTP_PASSWORD=<App Password de 16 dígitos> (no la contraseña normal).
# Si se dejan vacías, los correos se simulan en consola (no se envían).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"   # "true" si usas el puerto 465
SMTP_USER=""
SMTP_PASSWORD=""
MAIL_FROM=""          # por defecto usa SMTP_USER
