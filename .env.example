# =============================================================================
# Variables de entorno — copiar a .env.local y completar
# =============================================================================

# --- Base de datos (PostgreSQL) ---
DATABASE_URL="postgresql://user:password@localhost:5432/contratacion?schema=public"

# --- Auth.js (NextAuth v5) ---
AUTH_SECRET="genera-uno-con: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# --- Grok (xAI API) ---
GROK_API_KEY=""
GROK_API_BASE_URL="https://api.x.ai/v1"
GROK_MODEL="grok-2-latest"

# --- Almacenamiento de archivos (Vercel Blob / S3) ---
BLOB_READ_WRITE_TOKEN=""
# Alternativa S3:
# S3_ENDPOINT=""
# S3_BUCKET=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_REGION=""

# --- Correo (Resend / SMTP) ---
MAIL_PROVIDER="resend" # resend | smtp
RESEND_API_KEY=""
MAIL_FROM="no-reply@oss.example.co"
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASSWORD=""
